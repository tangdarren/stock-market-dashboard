# Backend environment. NEVER commit a real key.
# The frontend must not have access to any of these variables.

# Alpha Vantage — obtain a free key at https://www.alphavantage.co/support/#api-key.
ALPHA_VANTAGE_API_KEY=replace_with_your_key

# Rate-limit configuration (free tier limits Alpha Vantage aggressively).
ALPHA_VANTAGE_DAILY_BUDGET=20
ALPHA_VANTAGE_MIN_INTERVAL_SECONDS=15

# CORS: the only browser origin allowed to call this API in production.
FRONTEND_ORIGIN=http://localhost:5173

# Environment marker: development | production
APP_ENV=development
