# Frontend environment (safe to commit as an example).
# Vite exposes only variables prefixed with VITE_ to the browser.
# The Alpha Vantage API key MUST NOT live here — it belongs in server/.env.

VITE_API_BASE_URL=http://localhost:8000

# Optional: force the frontend into demo mode without any backend.
# Leave unset for normal use. When true, every panel is labelled "Demo data".
# VITE_DEMO_MODE=false
